PORT=3002
NODE_ENV="development"

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pharmanode
DB_PORT=5432

# Prisma Database URL (points to localhost for local development with docker db)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pharmanode?schema=public"

# JWT Secrets
JWT_ACCESS_SECRET="your_access_secret_key_change_me_to_something_very_secure"
JWT_REFRESH_SECRET="your_refresh_secret_key_change_me_to_something_very_secure"

# JWT Expirations
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
